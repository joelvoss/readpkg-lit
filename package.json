{
  "name": "readpkg-lit",
  "description": "This package finds and parses the closest `package.json`",
  "version": "2.3.0",
  "author": "Joel Voss <mail@joelvoss.com>",
  "license": "MIT",
  "homepage": "https://github.com/joelvoss/readpkg-lit",
  "bugs": {
    "url": "https://github.com/joelvoss/readpkg-lit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joelvoss/readpkg-lit.git"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "source": "./src/index.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "scripts": {
    "test": "./Taskfile.sh test",
    "prepublishOnly": "./Taskfile.sh build"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "@types/normalize-package-data": "2.4.4",
    "jsdom": "29.1.1",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-plugin-bundle-dts": "0.4.0",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "findup-lit": "2.4.0",
    "normalize-package-data": "9.0.0"
  }
}
